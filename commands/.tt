import axios from 'axios';

export const name = 'tt';
export const category = 'Downloader';
export const description = 'Download TikTok videos';

export async function execute({ sock, msg, from, args }) {
  if (!args[0]) {
    return await sock.sendMessage(from, {
      text: `❌ Please provide a TikTok URL!\n\nExample:\n.tt https://vm.tiktok.com/xxxxx`
    });
  }

  const url = args[0];

  if (!url.includes('tiktok.com')) {
    return await sock.sendMessage(from, {
      text: '❌ Invalid TikTok URL! Please send a valid TikTok link.'
    });
  }

  await sock.sendMessage(from, { text: '⏳ Downloading TikTok video...' });

  try {
    const response = await axios.get(
      `https://api.tiklydown.eu.org/api/download?url=${encodeURIComponent(url)}`
    );

    const data = response.data;

    if (!data || !data.video) {
      return await sock.sendMessage(from, {
        text: '❌ Could not download video. Try another link!'
      });
    }

    const videoUrl = data.video.noWatermark || data.video.watermark;
    const title = data.title || 'TikTok Video';
    const author = data.author?.nickname || 'Unknown';

    await sock.sendMessage(from, {
      video: { url: videoUrl },
      caption: `✅ *TikTok Video*\n\n📝 *Title:* ${title}\n👤 *Author:* ${author}\n\n_Downloaded by SpeedyMD_ ⚡`
    });

  } catch (err) {
    console.error('❌ TikTok error:', err.message);
    await sock.sendMessage(from, {
      text: '❌ Failed to download! The link might be invalid or private.\n\nTry again with a different link.'
    });
  }
}